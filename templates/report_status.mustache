{{!
    @template plagiarism_inspera/report_status

    Example context (json):
    {
        "status": "finished",
        "submissionid": "123",
        "displaytype": "originality",
        "html": "<div class='badge'>85%</div>"
    }
}}
<div class="{{wrapperclass}}"
     data-inspera-status="{{status}}"
     data-submissionid="{{id}}"
     data-displaytype="{{displaytype}}">

    {{#isfinished}}
        <a href="{{url}}" target="_blank">
            {{{iconhtml}}} {{linkprefix}}
            <span class="originality-score {{riskclass}}">{{scoretext}}</span>
        </a>
    {{/isfinished}}

    {{#isrequested}}
        {{statustext}}
    {{/isrequested}}

    {{#ispending}}
        {{statustext}}
    {{/ispending}}

    {{#iserror}}
        {{statustext}}
        {{#hasdescription}}
            <div class="originality-error-desc small text-muted mt-1" title="{{rawdescription}}">
                {{shortdescription}}
            </div>
        {{/hasdescription}}
    {{/iserror}}
</div>
