{{!
    @template plagiarism_inspera/debug_page

    Submissions Management Page Template.

    Context variables required for this template:
    * showallvalue - The target state for the toggle (-1 or 1).
    * toggleclass - CSS class for the toggle button.
    * togglelabel - Label for the toggle button.
    * filterhtml - HTML string for the filter bar.
    * posturl - Target URL for the bulk action form.
    * sesskey - The user session key.
    * tablehtml - The rendered Moodle table.
    * deletelabel - Text for the delete button.
    * resubmitlabel - Text for the resubmit button.

    Example context (json):
    {
        "showallvalue": 1,
        "toggleclass": "btn-primary",
        "togglelabel": "Show All",
        "filterhtml": "<div>Filter Placeholder</div>",
        "posturl": "originality_debug.php",
        "sesskey": "abcde12345",
        "tablehtml": "<table><tr><td>Example Table</td></tr></table>",
        "deletelabel": "Delete Selected",
        "resubmitlabel": "Resubmit Selected"
    }
}}
<div class="plagiarism_inspera_debug_page">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="view-toggle">
            <form action="{{posturl}}" method="post" class="m-0 p-0">
                <input type="hidden" name="sesskey" value="{{sesskey}}">
                <input type="hidden" name="showall" value="{{showallvalue}}">
                <button type="submit" class="btn {{toggleclass}}">{{togglelabel}}</button>
            </form>
        </div>
    </div>

    <div class="filter-container mb-4">
        {{{filterhtml}}}
    </div>
    <form action="{{posturl}}" method="post" id="debugform">
        <input type="hidden" name="sesskey" value="{{sesskey}}">

        <div class="submissions-table-container">
            {{{tablehtml}}}
        </div>
    </form>

    <div class="p-3 mt-3 border-top d-flex align-items-center justify-content-between bg-white">
        <div class="text-muted small text-uppercase font-weight-bold">
            {{#str}} bulkactions, plagiarism_inspera {{/str}}
        </div>
        <div class="buttons">
            <button name="deleteselectedfiles" value="1" type="submit" id="deleteallselected"
                    class="btn btn-outline-danger btn-sm" form="debugform">
                <i class="icon fa fa-trash" aria-hidden="true"></i> {{deletelabel}}
            </button>

            <button name="resubmitselectedfiles" value="1" type="submit" id="resubmitselected"
                    class="btn btn-outline-primary btn-sm ml-2" form="debugform">
                <i class="icon fa fa-refresh" aria-hidden="true"></i> {{resubmitlabel}}
            </button>
        </div>
    </div>
</div>
