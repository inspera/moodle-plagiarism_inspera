<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="plagiarism/inspera/db" VERSION="2026031600" COMMENT="Tables for Inspera originality plagiarism plugin">
    <TABLES>
        <TABLE NAME="plagiarism_inspera_subs" COMMENT="Submissions for originality check">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" NEXT="cm"/>
                <FIELD NAME="cm" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" PREVIOUS="id" NEXT="submissionid"/>
                <FIELD NAME="submissionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Link to mdl_assign_submission.id" PREVIOUS="cm" NEXT="userid"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="The specific user who uploaded this version (Audit trail only)" PREVIOUS="submissionid" NEXT="identifier"/>
                <FIELD NAME="identifier" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false" PREVIOUS="userid" NEXT="status"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" PREVIOUS="identifier" NEXT="timecreated"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" PREVIOUS="status" NEXT="timemodified"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false" PREVIOUS="timecreated" NEXT="externalid"/>
                <FIELD NAME="externalid" TYPE="char" LENGTH="64" NOTNULL="false" COMMENT="External document ID identifier" PREVIOUS="timemodified" NEXT="similarity"/>
                <FIELD NAME="similarity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" PREVIOUS="externalid" NEXT="originality_score"/>
                <FIELD NAME="originality_score" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" SEQUENCE="false" PREVIOUS="similarity" NEXT="translation_similarity"/>
                <FIELD NAME="translation_similarity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false" PREVIOUS="originality_score" NEXT="ai_index"/>
                <FIELD NAME="ai_index" TYPE="char" LENGTH="10" NOTNULL="false" PREVIOUS="translation_similarity" NEXT="originality"/>
                <FIELD NAME="originality" TYPE="char" LENGTH="20" NOTNULL="false" PREVIOUS="ai_index" NEXT="character_replacement"/>
                <FIELD NAME="character_replacement" TYPE="int" LENGTH="10" NOTNULL="false" PREVIOUS="originality" NEXT="hidden_text"/>
                <FIELD NAME="hidden_text" TYPE="int" LENGTH="10" NOTNULL="false" PREVIOUS="character_replacement" NEXT="image_as_text"/>
                <FIELD NAME="image_as_text" TYPE="int" LENGTH="10" NOTNULL="false" PREVIOUS="hidden_text" NEXT="storedfileid"/>
                <FIELD NAME="storedfileid" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Moodle stored file ID" PREVIOUS="image_as_text" NEXT="description"/>
                <FIELD NAME="description" TYPE="text" NOTNULL="false" COMMENT="Error message/description for failed submissions" PREVIOUS="storedfileid"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="cm" TYPE="foreign" FIELDS="cm" REFTABLE="course_modules" REFFIELDS="id"/>
                <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="submissionid" TYPE="foreign" FIELDS="submissionid" REFTABLE="assign_submission" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="submission_file" UNIQUE="false" FIELDS="submissionid, storedfileid" COMMENT="Fast lookup for group reports"/>
                <INDEX NAME="cm_userid_storedfile" UNIQUE="false" FIELDS="cm, userid, storedfileid" COMMENT="Legacy Find records by cm, user, and file"/>
                <INDEX NAME="cm_userid_identifier" UNIQUE="false" FIELDS="cm, userid, identifier" COMMENT="Legacy Find records by cm, user, and identifier"/>
                <INDEX NAME="status" UNIQUE="false" FIELDS="status" COMMENT="Query by status"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="plagiarism_inspera_config" COMMENT="config for modules">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" NEXT="cm"/>
                <FIELD NAME="cm" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" PREVIOUS="id" NEXT="name"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false" PREVIOUS="cm" NEXT="value"/>
                <FIELD NAME="value" TYPE="text" NOTNULL="true" SEQUENCE="false" PREVIOUS="name"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>
    </TABLES>
</XMLDB>