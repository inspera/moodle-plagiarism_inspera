<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="plagiarism/originality/db" VERSION="2026012900" COMMENT="Tables for originality plagiarism plugin (Description column for errors)">

    <TABLES>
        <TABLE NAME="plagiarism_originality_subs" COMMENT="Submissions for originality check">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="cm" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="submissionid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Link to mdl_assign_submission.id"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="The specific user who uploaded this version (Audit trail only)"/>
                <FIELD NAME="identifier" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <!-- API-related fields -->
                <FIELD NAME="externalid" TYPE="char" LENGTH="64" NOTNULL="false" COMMENT="External document ID identifier"/>
                <FIELD NAME="similarity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
                <FIELD NAME="translation_similarity" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="false"/>
                <FIELD NAME="ai_index" TYPE="char" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="originality" TYPE="char" LENGTH="20" NOTNULL="false"/>
                <FIELD NAME="character_replacement" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="hidden_text" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="image_as_text" TYPE="int" LENGTH="10" NOTNULL="false"/>
                <FIELD NAME="storedfileid" TYPE="int" LENGTH="10" NOTNULL="false" COMMENT="Moodle stored file ID"/>
                <!-- Single Description field to store error messages/details -->
                <FIELD NAME="description" TYPE="text" NOTNULL="false" COMMENT="Error message/description for failed submissions"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="cm" TYPE="foreign" FIELDS="cm" REFTABLE="course_modules" REFFIELDS="id"/>
                <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>

                <KEY NAME="submissionid" TYPE="foreign" FIELDS="submissionid" REFTABLE="assign_submission" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="submission_file" UNIQUE="false" FIELDS="submissionid, storedfileid" COMMENT="Fast lookup for group reports"/>
                <INDEX NAME="cm_userid_storedfile" UNIQUE="false" FIELDS="cm, userid, storedfileid" COMMENT="Legacy Find records by cm, user, and file"/>
                <INDEX NAME="cm_userid_identifier" UNIQUE="false" FIELDS="cm, userid, identifier" COMMENT="Legacy Find records by cm, user, and identifier"/>
                <INDEX NAME="status" UNIQUE="false" FIELDS="status" COMMENT="Query by status"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="plagiarism_originality_conf" COMMENT="config for modules">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="cm" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
                <FIELD NAME="value" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>
        </TABLE>

    </TABLES>
</XMLDB>
